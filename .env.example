# Google Gemini API (free tier: 15 RPM, 1M tokens/day)
# Get key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# NCBI API Key (optional but recommended)
# Raises PubMed rate limit from 3 to 10 requests/second
# Register free at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=your_ncbi_api_key_here

# Groq API (optional — fallback LLM if Gemini quota exceeded)
# Free tier at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
